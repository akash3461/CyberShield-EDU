{
  "manifest_version": 3,
  "name": "CyberShield EDU Protector",
  "version": "1.0",
  "description": "Real-time AI scam detection for students.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8000/*"]
}
